<?xml version="1.0" encoding="utf-8"?>
<!-- SmartCard Widget 佈局
     支援三種模式：noMatch / singleCard / multipleCards
     multipleCards 模式下使用 StackView 上下滑動切換卡片 -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="8dp"
    android:background="@android:color/white">

    <!-- 頂部列：App icon + 店名 + 頁碼指示器 -->
    <LinearLayout
        android:id="@+id/widget_top_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:visibility="gone">

        <ImageView
            android:id="@+id/widget_app_icon"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@mipmap/ic_launcher"
            android:layout_marginEnd="6dp"
            android:contentDescription="SmartCard" />

        <TextView
            android:id="@+id/widget_store_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="13sp"
            android:textColor="#333333"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end" />

        <!-- 頁碼指示器，例如 "1/3"，僅單卡時使用（多卡由 StackView item 自帶） -->
        <TextView
            android:id="@+id/widget_page_indicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="#888888"
            android:layout_marginStart="8dp"
            android:visibility="gone" />
    </LinearLayout>

    <!-- 中間：條碼圖片（singleCard / noMatch 模式使用） -->
    <ImageView
        android:id="@+id/widget_barcode_image"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scaleType="fitXY"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="2dp"
        android:visibility="gone"
        android:contentDescription="條碼" />

    <!-- StackView：multipleCards 模式上下滑動切換卡片 -->
    <StackView
        android:id="@+id/widget_stack_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="gone" />

    <!-- 隱藏的 title（供 Kotlin HomeWidgetPlugin 相容） -->
    <TextView
        android:id="@+id/widget_title"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone" />

    <!-- 空狀態：無卡片時顯示 -->
    <TextView
        android:id="@+id/widget_empty_text"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:text="點擊新增會員卡"
        android:textSize="12sp"
        android:textColor="#999999"
        android:visibility="gone" />

    <!-- 最近門市提示（無符合時顯示） -->
    <TextView
        android:id="@+id/widget_nearest_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textSize="11sp"
        android:textColor="#888888"
        android:paddingBottom="4dp"
        android:visibility="gone" />

</LinearLayout>
