<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="#FFFFFF"
    android:padding="8dp"
    android:clickable="true">

    <!-- 左欄：icon + 條碼 + 店名 -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/widget_item_icon"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@mipmap/ic_launcher"
            android:contentDescription="App icon" />

        <ImageView
            android:id="@+id/widget_item_barcode"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:scaleType="fitCenter"
            android:contentDescription="Barcode" />

        <TextView
            android:id="@+id/widget_item_store_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:textSize="13sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end" />
    </LinearLayout>

    <!-- 右欄：▲ 頁碼 ▼ -->
    <LinearLayout
        android:layout_width="48dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center">

        <TextView
            android:id="@+id/widget_item_arrow_up"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="▲"
            android:textSize="14sp"
            android:gravity="center" />

        <TextView
            android:id="@+id/widget_item_page_indicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="#888888"
            android:gravity="center" />

        <TextView
            android:id="@+id/widget_item_arrow_down"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="▼"
            android:textSize="14sp"
            android:gravity="center" />
    </LinearLayout>

</LinearLayout>
