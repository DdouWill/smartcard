<?xml version="1.0" encoding="utf-8"?>
<!-- Widget 背景：深藍色圓角矩形 -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="#CC1565C0" />
    <!-- 半透明深藍（讓桌面壁紙略透）-->
    <corners android:radius="16dp" />
    <!-- 圓角 -->
    <stroke
        android:width="1dp"
        android:color="#332196F3" />
    <!-- 淡藍色邊框 -->
</shape>
